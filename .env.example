# Mqulima Environment Variables
# Copy to .env and fill in values

# PostgreSQL Database
DATABASE_URL=postgresql://mqulima:your_password@localhost:5433/mqulima_dev

# JWT Authentication Secret (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here

# M-Pesa Daraja API (Phase 3)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_ENVIRONMENT=sandbox

# Flutterwave (Phase 3)
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=

# Public (shipped to browser)
VITE_APP_URL=http://localhost:3000

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here
